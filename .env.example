# clientside-containers environment configuration
# Copy to .env.local and adjust as needed.

# Backend mode. "simulation" (default) runs an in-process model of the
# OpenShell gateway so the app works without external infrastructure.
# Set to "gateway" to proxy requests to a real OpenShell gateway.
CSC_MODE=simulation

# Base URL of a running OpenShell gateway control-plane API.
# Used only when CSC_MODE=gateway.
# See: https://github.com/NVIDIA/OpenShell
OPENSHELL_GATEWAY_URL=http://127.0.0.1:18080

# Optional bearer token presented to the OpenShell gateway.
OPENSHELL_GATEWAY_TOKEN=
