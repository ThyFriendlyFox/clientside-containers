{
  "name": "clientside-containers-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop companion that runs exported clientside-containers environments locally and starts them on boot.",
  "license": "GPL-3.0-only",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.clientside-containers.desktop",
    "productName": "clientside-containers Desktop",
    "files": ["main.js", "preload.js", "renderer/**/*"],
    "mac": { "category": "public.app-category.developer-tools" },
    "linux": { "target": ["AppImage"], "category": "Development" },
    "win": { "target": ["nsis"] }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
